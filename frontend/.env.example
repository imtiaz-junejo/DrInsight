NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DrInsight
NEXT_PUBLIC_VIDEO_PROVIDER=WEBRTC
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Must match backend JWT_ACCESS_SECRET — required for proxy route protection
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long

# Disable Next.js anonymous telemetry in local dev
NEXT_TELEMETRY_DISABLED=1
