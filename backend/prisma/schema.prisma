  featured        Boolean           @default(false)
  displayOrder    Int               @default(0)
  usageCount      Int               @default(0)
  seoTitle        String?
  seoDescription  String?
  metaKeywords    String[]          @default([])
  settings        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  usages          HealthToolUsage[]

  @@index([isActive, displayOrder])
  @@index([featured])
  @@index([category])
  @@map("health_tools")
}

model HealthToolUsage {
  id            String     @id @default(cuid())
  toolId        String
  userId        String?
  sessionId     String?
  resultSummary String?
  notes         String?
  resultJson    Json?
  createdAt     DateTime   @default(now())
  tool          HealthTool @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([toolId, createdAt])
  @@index([userId, createdAt])
  @@map("health_tool_usages")
}

model PageView {
  id              String   @id @default(cuid())
  path            String
  referrer        String?
  sessionId       String?
  durationSeconds Int?
  createdAt       DateTime @default(now())

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
  @@index([referrer])
  @@map("page_views")
}

model ReviewProcessSettings {
  id                       String   @id @default("default")
  tier1MinYears            Int      @default(5)
  tier2MinYears            Int      @default(7)
  reviewDeadlineDays       Int      @default(7)
  maxRevisionCycles        Int      @default(2)
  authorRevisionWindowDays Int      @default(5)
  minSourcesPerArticle     Int      @default(5)
  updatedAt                DateTime @updatedAt

  @@map("review_process_settings")
}

model ContentCurrencySchedule {
  id                String   @id @default(cuid())
  contentType       String   @unique
  reviewCycleMonths Int
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("content_currency_schedules")
}

model AdminRole {
  id           String           @id @default(cuid())
  key          String           @unique
  name         String
  description  String?
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  permissions  RolePermission[]

  @@map("admin_roles")
}

model AdminPermission {
  id           String           @id @default(cuid())
  key          String           @unique
  name         String
  displayOrder Int              @default(0)
  roles        RolePermission[]

  @@map("admin_permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  enabled      Boolean         @default(true)
  permission   AdminPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         AdminRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model doctor_publications {
  id              String        @id
  doctorId        String
  title           String
  journal         String
  publicationYear Int
  doi             String?
  url             String?
  abstract        String?
  citations       Int           @default(0)
  authors         String?
  publisher       String?
  volume          String?
  issue           String?
  pages           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  doctor_profiles DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([publicationYear])
}

model ArticleReviewHistory {
  id            String              @id @default(cuid())
  postId        String
  actorId       String
  action        ArticleReviewAction
  fromStatus    BlogStatus?
  toStatus      BlogStatus?
  notes         String?
  internalNotes String?
  createdAt     DateTime            @default(now())
  actor         User                @relation("ArticleReviewActor", fields: [actorId], references: [id], onDelete: Cascade)
  post          BlogPost            @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([actorId])
  @@map("article_review_history")
}

model EditorialReview {
  id            String                 @id @default(cuid())
  postId        String?                @unique
  publicationId String?                @unique
  currentStage  EditorialReviewStageType @default(SUBMITTED)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  post          BlogPost?              @relation(fields: [postId], references: [id], onDelete: Cascade)
  publication   Publication?           @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  stages        EditorialReviewStage[]

  @@index([currentStage])
  @@map("editorial_reviews")
}

model EditorialReviewStage {
  id            String                   @id @default(cuid())
  reviewId      String
  stage         EditorialReviewStageType
  reviewerId    String?
  reviewDate    DateTime?
  dueDate       DateTime?
  status        EditorialStageStatus     @default(PENDING)
  notes         String?
  medicalNotes  String?
  internalNotes String?
  completedAt   DateTime?
  displayOrder  Int                      @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  review        EditorialReview          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewer      User?                    @relation("EditorialStageReviewer", fields: [reviewerId], references: [id])

  @@unique([reviewId, stage])
  @@index([reviewId, displayOrder])
  @@index([reviewerId])
  @@map("editorial_review_stages")
}

model MedicalReviewer {
  id           String   @id @default(cuid())
  userId       String   @unique
  tier         Int      @default(1)
  specialty    String?
  isActive     Boolean  @default(true)
  maxWorkload  Int      @default(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive, tier])
  @@map("medical_reviewers")
}

model EditorialPolicy {
  id            String                  @id @default(cuid())
  title         String
  slug          String                  @unique
  category      EditorialPolicyCategory
  version       String                  @default("1.0")
  effectiveDate DateTime?
  status        EditorialDocumentStatus @default(DRAFT)
  contentHtml   String?
  seoTitle      String?
  seoDescription String?
  metaKeywords  String[]                @default([])
  isCurrent     Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  versions      EditorialPolicyVersion[]

  @@index([category, status])
  @@index([isCurrent])
  @@map("editorial_policies")
}

model EditorialPolicyVersion {
  id             String          @id @default(cuid())
  policyId       String
  versionNumber  String
  title          String
  contentHtml    String?
  changeLog      String?
  seoTitle       String?
  seoDescription String?
  metaKeywords   String[]        @default([])
  isCurrent      Boolean         @default(false)
  createdById    String?
  createdAt      DateTime        @default(now())
  createdBy      User?           @relation(fields: [createdById], references: [id])
  policy         EditorialPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, versionNumber])
  @@index([policyId, isCurrent])
  @@map("editorial_policy_versions")
}

model AuthorGuideline {
  id            String                  @id @default(cuid())
  title         String
  slug          String                  @unique
  category      AuthorGuidelineCategory
  version       String                  @default("1.0")
  status        EditorialDocumentStatus @default(DRAFT)
  contentHtml   String?
  seoTitle      String?
  seoDescription String?
  metaKeywords  String[]                @default([])
  isCurrent     Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  versions      AuthorGuidelineVersion[]
  attachments   AuthorGuidelineAttachment[]

  @@index([category, status])
  @@index([isCurrent])
  @@map("author_guidelines")
}

model AuthorGuidelineVersion {
  id             String          @id @default(cuid())
  guidelineId    String
  versionNumber  String
  title          String
  contentHtml    String?
  changeLog      String?
  seoTitle       String?
  seoDescription String?
  metaKeywords   String[]        @default([])
  isCurrent      Boolean         @default(false)
  createdById    String?
  createdAt      DateTime        @default(now())
  createdBy      User?           @relation(fields: [createdById], references: [id])
  guideline      AuthorGuideline @relation(fields: [guidelineId], references: [id], onDelete: Cascade)

  @@unique([guidelineId, versionNumber])
  @@index([guidelineId, isCurrent])
  @@map("author_guideline_versions")
}

model AuthorGuidelineAttachment {
  id          String          @id @default(cuid())
  guidelineId String
  fileName    String
  fileUrl     String
  fileSize    Int?
  mimeType    String?
  createdAt   DateTime        @default(now())
  guideline   AuthorGuideline @relation(fields: [guidelineId], references: [id], onDelete: Cascade)

  @@index([guidelineId])
  @@map("author_guideline_attachments")
}

