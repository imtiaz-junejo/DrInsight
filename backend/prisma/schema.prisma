generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            String                 @id @default(cuid())
  email                         String                 @unique
  passwordHash                  String?
  firstName                     String
  lastName                      String
  role                          UserRole               @default(PATIENT)
  status                        UserStatus             @default(PENDING)
  avatarUrl                     String?
  phone                         String?
  emailVerified                 Boolean                @default(false)
  profileCompletedAt            DateTime?
  lastSeenAt                    DateTime?
  isOnline                      Boolean                @default(false)
  accountSettings               Json?
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  answeredQuestions             AskDoctorQuestion[]    @relation("AnsweredBy")
  blogPosts                     BlogPost[]
  reviewedBlogPosts             BlogPost[]             @relation("BlogReviewer")
  articleReviewActions          ArticleReviewHistory[] @relation("ArticleReviewActor")
  editorialPolicyVersions       EditorialPolicyVersion[]
  authorGuidelineVersions       AuthorGuidelineVersion[]
  editorialReviewAssignments    EditorialReviewStage[] @relation("EditorialStageReviewer")
  medicalReviewerProfile        MedicalReviewer?
  assignedContactInquiries      ContactSubmission[]    @relation("ContactInquiryAssignee")
  contactInquiryReplies         ContactInquiryReply[]  @relation("ContactInquiryReplies")
  contactInquiryNotes           ContactInquiryNote[]   @relation("ContactInquiryNotes")
  doctorProfile                 DoctorProfile?
  emailTemplatesCreated         EmailTemplate[]        @relation("EmailTemplatesCreated")
  newsletterCampaignsCreated    NewsletterCampaign[]   @relation("NewsletterCampaignsCreated")
  sentMessages                  Message[]              @relation("SentMessages")
  targetedNotificationCampaigns NotificationCampaign[] @relation("NotificationCampaignAudience")
  notificationCampaignsCreated  NotificationCampaign[] @relation("NotificationCampaignsCreated")
  notifications                 Notification[]
  oauthAccounts                 OAuthAccount[]
  otpTemplatesCreated           OtpTemplate[]          @relation("OtpTemplatesCreated")
  passwordResetTokens           PasswordResetToken[]
  emailVerificationTokens       EmailVerificationToken[]
  patientProfile                PatientProfile?
  authoredClinicalNotes         PatientClinicalNote[]  @relation("ClinicalNoteAuthor")
  publicationBookmarks          PublicationBookmark[]
  blogPostBookmarks             BlogPostBookmark[]
  submittedQuestions            AskDoctorQuestion[]    @relation("QuestionSubmitter")
  healthToolUsages              HealthToolUsage[]
  publicationReviews            PublicationReview[]
  reviewedPublications          Publication[]          @relation("PublicationReviewer")
  refreshTokens                 RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model OAuthAccount {
  id         String        @id @default(cuid())
  provider   OAuthProvider
  providerId String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@unique([provider, userId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model DoctorProfile {
  id                    String                @id @default(cuid())
  userId                String                @unique
  doctorNumber          String?               @unique
  specialty             String
  subSpecialty          String?
  licenseNumber         String                @unique
  bio                   String?
  experienceYears       Int                   @default(0)
  consultationFee       Decimal               @default(0) @db.Decimal(10, 2)
  rating                Float                 @default(0)
  reviewCount           Int                   @default(0)
  availability          DoctorAvailability    @default(OFFLINE)
  languages             String[]              @default([])
  education             String?
  hospital              String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  bioFull               String?
  credentials           String?
  professionalTitle     String?
  patientsTreated       Int                   @default(0)
  successRate           Float?
  responseTime          String?
  expertise             String[]              @default([])
  services              String[]              @default([])
  researchTags          String[]              @default([])
  educationHistory      Json?
  certifications        Json?
  publications          Json?
  awards                Json?
  speakingEngagements   Json?
  weeklySchedule        Json?
  clinicSchedule        Json?
  onlineSchedule        Json?
  city                  String?
  country               String?               @default("Pakistan")
  gender                String?
  dateOfBirth           DateTime?
  address               String?
  licenseCertificateUrl String?
  coverImageUrl         String?
  linkedinUrl           String?
  twitterUrl            String?
  youtubeUrl            String?
  websiteUrl            String?
  orcidUrl              String?
  researchGateUrl       String?
  googleScholarUrl      String?
  facebookUrl           String?
  instagramUrl          String?
  authorType            AuthorType            @default(DOCTOR)
  bookingEnabled        Boolean               @default(true)
  onlineAvailEnabled    Boolean               @default(true)
  physicalAvailEnabled  Boolean               @default(true)
  researchGrantsTotal   String?
  licenseBoard          String?
  verificationNote      String?
  platformRole          String?
  editorialBoard        Boolean               @default(false)
  medicalReviewerFor    String?
  conflictOfInterest    String?
  credentialsVerifiedAt DateTime?
  profileSlug           String?               @unique
  seoFocusKeyword       String?
  seoMetaTitle          String?
  seoMetaDescription    String?
  seoSchemaJson         Json?
  appointments          Appointment[]         @relation("DoctorAppointments")
  bookingDrafts         BookingDraft[]
  conversations         Conversation[]        @relation("DoctorConversations")
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctor_publications   doctor_publications[]
  prescriptions         Prescription[]        @relation("DoctorPrescriptions")
  clinicalNotes         PatientClinicalNote[] @relation("DoctorClinicalNotes")
  labOrders             LabOrder[]            @relation("DoctorLabOrders")
  criticalAlerts        PatientCriticalAlert[] @relation("DoctorCriticalAlerts")
  prescriptionDrafts    PrescriptionDraft[]   @relation("DoctorPrescriptionDrafts")
  submittedPublications Publication[]
  reviews               Review[]
  assignedQuestions     AskDoctorQuestion[] @relation("DoctorAssignedQuestions")
  profileFeedback       AuthorProfileFeedback[]

  @@index([specialty])
  @@index([availability])
  @@index([city])
  @@map("doctor_profiles")
}

model AuthorProfileFeedback {
  id              String        @id @default(cuid())
  doctorProfileId String
  helpful         Boolean
  viewerKey       String?
  createdAt       DateTime      @default(now())
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)

  @@index([doctorProfileId])
  @@index([viewerKey])
  @@map("author_profile_feedback")
}

model PatientProfile {
  id               String         @id @default(cuid())
  userId           String         @unique
  patientNumber    String?        @unique
  dateOfBirth      DateTime?
  gender           String?
  bloodGroup       String?
  allergies        String[]       @default([])
  medicalHistory   String?
  emergencyContact String?
  city             String?
  province         String?
  country          String?
  address          String?
  postalCode       String?
  accountSubType   String?
  healthInterests  String[]       @default([])
  contentPreference String?
  newsletterFrequency String?
  languagePreference String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  appointments     Appointment[]  @relation("PatientAppointments")
  bookingDrafts    BookingDraft[]
  conversations    Conversation[] @relation("PatientConversations")
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  prescriptions      Prescription[]         @relation("PatientPrescriptions")
  clinicalNotes      PatientClinicalNote[]  @relation("PatientClinicalNotes")
  labOrders          LabOrder[]             @relation("PatientLabOrders")
  criticalAlerts     PatientCriticalAlert[] @relation("PatientCriticalAlerts")
  prescriptionDrafts PrescriptionDraft[]    @relation("PatientPrescriptionDrafts")
  reviews            Review[]
  vitalReadings      PatientVitalReading[]

  @@map("patient_profiles")
}

model Appointment {
  id               String            @id @default(cuid())
  patientId        String
  doctorId         String
  scheduledAt      DateTime
  durationMinutes  Int               @default(30)
  status           AppointmentStatus @default(PENDING)
  consultationType ConsultationType  @default(VIDEO)
  bookingSource    BookingSource     @default(ONLINE)
  bookedByUserId   String?
  reason           String?
  notes            String?
  meetingRoomId    String?
  roomId           String?
  meetingStatus    MeetingStatus     @default(WAITING)
  videoProvider    VideoProvider?
  startedAt        DateTime?
  endedAt          DateTime?
  durationSeconds  Int?
  doctorJoinedAt   DateTime?
  patientJoinedAt  DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  doctor           DoctorProfile     @relation("DoctorAppointments", fields: [doctorId], references: [id])
  patient          PatientProfile    @relation("PatientAppointments", fields: [patientId], references: [id])
  conversation     Conversation?
  payment          Payment?
  prescription     Prescription?
  clinicalNotes    PatientClinicalNote[]
  review           Review?
  meeting          Meeting?
  labOrders        LabOrder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([status])
  @@index([meetingStatus])
  @@index([roomId])
  @@index([meetingRoomId])
  @@index([bookingSource])
  @@map("appointments")
}

model Meeting {
  id            String               @id @default(uuid())
  appointmentId String               @unique
  roomId        String               @unique
  status        MeetingStatus        @default(WAITING)
  startedAt     DateTime?
  endedAt       DateTime?
  durationSeconds Int?
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  appointment   Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  participants  MeetingParticipant[]
  events        MeetingEvent[]
  callLogs      CallLog[]
  connectionLogs ConnectionLog[]
  chats         MeetingChat[]
  attachments   MeetingAttachment[]
  audits        MeetingAudit[]
  recordings    MeetingRecording[]

  @@index([status])
  @@index([roomId])
  @@index([startedAt])
  @@map("meetings")
}

model MeetingParticipant {
  id           String              @id @default(uuid())
  meetingId    String
  userId       String
  role         MeetingParticipantRole
  socketId     String?
  joinedAt     DateTime?
  leftAt       DateTime?
  isConnected  Boolean             @default(false)
  cameraEnabled Boolean            @default(true)
  micEnabled   Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  meeting      Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  deviceInfo   DeviceInfo?
  networkStats NetworkStats[]

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
  @@map("meeting_participants")
}

model MeetingEvent {
  id         String           @id @default(uuid())
  meetingId  String
  userId     String?
  eventType  MeetingEventType
  payload    Json?
  createdAt  DateTime         @default(now())
  meeting    Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([eventType])
  @@index([createdAt])
  @@map("meeting_events")
}

model CallLog {
  id          String        @id @default(uuid())
  meetingId   String
  userId      String?
  action      CallLogAction
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime      @default(now())
  meeting     Meeting       @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("call_logs")
}

model ConnectionLog {
  id              String              @id @default(uuid())
  meetingId       String
  userId          String?
  state           ConnectionLogState
  iceState        String?
  signalingState  String?
  errorCode       String?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  meeting         Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
  @@index([state])
  @@index([createdAt])
  @@map("connection_logs")
}

model DeviceInfo {
  id            String             @id @default(uuid())
  participantId String             @unique
  browser       String?
  os            String?
  deviceType    String?
  cameraLabel   String?
  microphoneLabel String?
  screenWidth   Int?
  screenHeight  Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  participant   MeetingParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("device_info")
}

model NetworkStats {
  id             String             @id @default(uuid())
  participantId  String
  quality        NetworkQuality
  packetLoss     Float?
  latencyMs      Float?
  bitrateKbps    Float?
  roundTripMs    Float?
  jitterMs       Float?
  rawStats       Json?
  createdAt      DateTime           @default(now())
  participant    MeetingParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([quality])
  @@index([createdAt])
  @@map("network_stats")
}

model MeetingChat {
  id          String            @id @default(uuid())
  meetingId   String
  senderId    String
  content     String
  replyToId   String?
  deliveredAt DateTime?
  seenAt      DateTime?
  seenById    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  meeting     Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  replyTo     MeetingChat?      @relation("ChatReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     MeetingChat[]     @relation("ChatReply")

  @@index([meetingId])
  @@index([senderId])
  @@index([replyToId])
  @@index([createdAt])
  @@map("meeting_chats")
}

model MeetingAttachment {
  id          String   @id @default(uuid())
  meetingId   String
  uploaderId  String
  fileName    String
  mimeType    String
  fileUrl     String
  fileSize    Int?
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([uploaderId])
  @@map("meeting_attachments")
}

model MeetingAudit {
  id         String           @id @default(uuid())
  meetingId  String
  actorId    String?
  action     MeetingAuditAction
  details    Json?
  ipAddress  String?
  createdAt  DateTime         @default(now())
  meeting    Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("meeting_audits")
}

model MeetingRecording {
  id          String           @id @default(uuid())
  meetingId   String
  storageUrl  String?
  status      RecordingStatus  @default(PENDING)
  startedAt   DateTime?
  endedAt     DateTime?
  durationSeconds Int?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([status])
  @@map("meeting_recordings")
}

model LabOrder {
  id            String         @id @default(uuid())
  appointmentId String
  doctorId      String
  patientId     String
  tests         Json
  instructions  String?
  priority      LabOrderPriority @default(ROUTINE)
  status        LabOrderStatus @default(ORDERED)
  orderedAt     DateTime       @default(now())
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        DoctorProfile  @relation("DoctorLabOrders", fields: [doctorId], references: [id])
  patient       PatientProfile @relation("PatientLabOrders", fields: [patientId], references: [id])

  @@index([appointmentId])
  @@index([doctorId])
  @@index([patientId])
  @@index([status])
  @@map("lab_orders")
}

model BookingDraft {
  id               String             @id @default(cuid())
  patientId        String
  doctorId         String
  scheduledAt      DateTime
  durationMinutes  Int                @default(30)
  consultationType ConsultationType   @default(VIDEO)
  reason           String?
  amountCents      Int
  currency         String             @default("usd")
  status           BookingDraftStatus @default(DRAFT)
  expiresAt        DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  doctor           DoctorProfile      @relation(fields: [doctorId], references: [id])
  patient          PatientProfile     @relation(fields: [patientId], references: [id])
  payment          Payment?

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([expiresAt])
  @@map("booking_drafts")
}

model Payment {
  id                   String        @id @default(cuid())
  bookingDraftId       String        @unique
  appointmentId        String?       @unique
  provider             String        @default("stripe")
  providerIntentId     String        @unique
  clientSecret         String
  amountCents          Int
  currency             String        @default("usd")
  status               PaymentStatus @default(REQUIRES_PAYMENT_METHOD)
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  confirmedAt          DateTime?
  patientId            String?
  doctorId             String?
  stripeChargeId       String?
  paymentMethod        String?
  receiptUrl           String?
  invoiceNumber        String?       @unique
  platformFeeCents     Int           @default(500)
  taxCents             Int           @default(0)
  consultationFeeCents Int           @default(0)
  billingName          String?
  billingEmail         String?
  billingCountry       String?
  appointment          Appointment?  @relation(fields: [appointmentId], references: [id])
  bookingDraft         BookingDraft  @relation(fields: [bookingDraftId], references: [id])

  @@index([status])
  @@index([patientId])
  @@index([doctorId])
  @@map("payments")
}

model BlogCategory {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  parentId    String?
  icon        String?
  color       String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  parent      BlogCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BlogCategory[] @relation("CategoryHierarchy")
  posts       BlogPost[]

  @@index([parentId])
  @@index([isActive])
  @@map("blog_categories")
}

model BlogTag {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  color       String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  posts       BlogPostTag[]

  @@index([isActive])
  @@map("blog_tags")
}

model BlogPostTag {
  postId String
  tagId  String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("blog_post_tags")
}

model BlogPost {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique
  excerpt           String
  content           String
  coverImageUrl     String?
  categoryId        String
  authorId          String
  status            BlogStatus       @default(DRAFT)
  readTimeMinutes   Int              @default(5)
  viewCount         Int              @default(0)
  tags              String[]         @default([])
  publishedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  featured          Boolean          @default(false)
  pinned            Boolean          @default(false)
  featuredOrder     Int?
  subtitle          String?
  coverImageAlt     String?
  coverImageCaption String?
  reviewerId        String?
  specialty         String?
  shareCount        Int              @default(0)
  summaryPoints     String[]         @default([])
  keyTakeaways      String[]         @default([])
  references        Json?
  glossary          Json?
  medicalDisclaimer String?
  peerReviewed      Boolean          @default(false)
  lastReviewedAt    DateTime?
  seoTitle          String?
  seoDescription    String?
  metaKeywords      String[]         @default([])
  canonicalUrl      String?
  averageRating     Float?
  ratingCount       Int              @default(0)
  helpfulYes        Int              @default(0)
  helpfulNo         Int              @default(0)
  comments          BlogComment[]
  ratings           BlogPostRating[]
  postTags          BlogPostTag[]
  author            User             @relation(fields: [authorId], references: [id])
  category          BlogCategory     @relation(fields: [categoryId], references: [id])
  reviewer          User?            @relation("BlogReviewer", fields: [reviewerId], references: [id])
  reviewPriority    ReviewPriority   @default(NORMAL)
  submittedAt       DateTime?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  revisionNotes     String?
  reviewHistories   ArticleReviewHistory[]
  editorialReview   EditorialReview?
  bookmarks         BlogPostBookmark[]

  @@index([categoryId])
  @@index([authorId])
  @@index([reviewerId])
  @@index([status])
  @@index([publishedAt])
  @@index([featured, featuredOrder])
  @@index([specialty])
  @@index([reviewPriority])
  @@index([submittedAt])
  @@map("blog_posts")
}

model BlogComment {
  id                String            @id @default(cuid())
  postId            String
  authorName        String
  authorEmail       String?
  content           String
  isVerifiedPatient Boolean           @default(false)
  status            BlogCommentStatus @default(PENDING)
  parentId          String?
  createdAt         DateTime          @default(now())
  parent            BlogComment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies           BlogComment[]     @relation("CommentReplies")
  post              BlogPost          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status])
  @@map("blog_comments")
}

model BlogPostRating {
  id        String   @id @default(cuid())
  postId    String
  raterKey  String
  rating    Int
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, raterKey])
  @@index([postId])
  @@map("blog_post_ratings")
}

model BlogPostBookmark {
  id          String   @id @default(cuid())
  userId      String
  postId      String
  readPercent Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post        BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("blog_post_bookmarks")
}

model PatientVitalReading {
  id         String       @id @default(cuid())
  patientId  String
  type       VitalType
  value      String
  unit       String?
  status     VitalStatus  @default(NORMAL)
  recordedAt DateTime     @default(now())
  notes      String?
  createdAt  DateTime     @default(now())
  patient    PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, type, recordedAt])
  @@index([patientId, recordedAt])
  @@map("patient_vital_readings")
}

model Conversation {
  id            String         @id @default(cuid())
  patientId     String
  doctorId      String
  appointmentId String?        @unique
  lastMessageAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment?   @relation(fields: [appointmentId], references: [id])
  doctor        DoctorProfile  @relation("DoctorConversations", fields: [doctorId], references: [id])
  patient       PatientProfile @relation("PatientConversations", fields: [patientId], references: [id])
  messages      Message[]

  @@unique([patientId, doctorId])
  @@index([patientId])
  @@index([doctorId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  type           MessageType  @default(TEXT)
  attachmentUrl  String?
  readAt         DateTime?
